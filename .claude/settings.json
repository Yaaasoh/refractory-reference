{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "refractory-reference-fresh"
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(cp:*)",
      "Bash(dos2unix:*)",
      "Bash(du:*)",
      "Bash(explorer:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(py:*)",
      "Bash(sed:*)",
      "Bash(start:*)",
      "Skill(finish)",
      "Skill(report)",
      "Skill(sync)",
      "Skill(update-docs)"
    ],
    "deny": [
      "Bash(git clean -fd:*)",
      "Bash(git reset --hard:*)",
      "Bash(python -:*)",
      "Bash(python :*)",
      "Bash(python3:*)",
      "Bash(rm -r :*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block_destructive.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/python_path_guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/protect_embeddings.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_file_size.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/transcript_work_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/quality_check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_encoding.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/diagram_quality_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ocr_workflow_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_sync.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_deploy_verification.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_public_repo.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/python_path_diagnose.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_rebuild.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_uncommitted.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_export.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto_activate_skills.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/prevent_false_completion.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/plan_mode_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config_change_guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
