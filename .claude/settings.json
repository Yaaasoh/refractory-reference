{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "refractory-reference-fresh"
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(cp:*)",
      "Bash(dos2unix:*)",
      "Bash(du:*)",
      "Bash(explorer:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(py:*)",
      "Bash(sed:*)",
      "Bash(start:*)",
      "Skill(finish)",
      "Skill(report)",
      "Skill(sync)",
      "Skill(update-docs)"
    ],
    "deny": [
      "Bash(git clean -fd:*)",
      "Bash(git reset --hard:*)",
      "Bash(python -:*)",
      "Bash(python :*)",
      "Bash(python3:*)",
      "Bash(rm -r :*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block_destructive.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/python_path_guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/protect_embeddings.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check_fork_push.sh",
            "timeout": 5,
            "if": "Bash(git push *)"
          },
          {
            "type": "command",
            "command": "echo '{\"decision\":\"block\",\"reason\":\"deploy.sh -f はユーザーの明示的指示がある場合のみ使用可能です。-fなしで実行してください。\"}'",
            "timeout": 5,
            "if": "Bash(*/deploy.sh*-f*)|Bash(*/deploy.sh*--force*)"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/preflight_citation_gate.sh",
            "timeout": 10,
            "if": "Bash(quarto render*)|Bash(quarto preview*)"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_file_size.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/transcript_work_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/quality_check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/protect_packages.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/warn_work_dir.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_encoding.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/diagram_quality_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ocr_workflow_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_sync.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/shellcheck_quality_loop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check_citation_placement.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_deploy_verification.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check_deploy_notices.sh",
            "timeout": 5,
            "if": "Bash(*/deploy.sh *)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_public_repo.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/python_path_diagnose.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_rebuild.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_uncommitted.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory_db_export.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check_websearch_saved.sh",
            "timeout": 30
          },
          {
            "type": "prompt",
            "prompt": "あなたはClaude Code応答の品質検査官です。入力JSONを評価してください。\n\n【即allow条件】\n- \"stop_hook_active\"がtrue → allow（無限ループ防止）\n- \"last_assistant_message\"が空・未存在・100文字未満 → allow\n\n【deny条件】以下に該当する場合のみdeny:\n- コードやドキュメントを確認せずに推測を事実として断定している（例: 関数の戻り値型、API仕様、設定値を検証なしに断言）\n- 「おそらく」「推測ですが」等の不確実性マーカーなしに検証していない情報を述べている\n\n【allow条件】以下は必ずallow:\n- 提案・推奨・質問への回答\n- 「確認しました」「読みました」「Readツールで確認」等の証拠参照がある記述\n- 一般的技術知識（言語仕様、フレームワーク基本動作）\n- ツール実行結果の報告\n\ndeny時は該当箇所を引用してください。\n\n$ARGUMENTS",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto_activate_skills.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/prevent_false_completion.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/plan_mode_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config_change_guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
